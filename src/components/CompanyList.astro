---
import type { Article } from '../types/article';
import articlesData from '../data/articles.json';

const articles: Article[] = articlesData;

// カテゴリー"COMPANY"の記事をフィルタリングし、最新3件を取得
const companyArticles = articles
  .filter(article => article.category.alphabet === "COMPANY")
  .slice(0, 3);
---

<ul class="company-list">
  {companyArticles.map((article) => (
    <li class="company-list__item">
      <a href={article.href}>
        <figure class="company-list__img">
          <img src={article.imageSrc} alt="" />
        </figure>
        <div class="company-list__detail">
          <p class="company-list__date">{article.date}</p>
          <p class="company-list__title">{article.title}</p>
          <ul class="company-list__tag">
            {article.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        </div>
      </a>
    </li>
  ))}
</ul>

<style lang="scss">
  @use '../scss/foundation/setting' as *;

  .company-list {
    margin-top: 80px;
    border-top: solid 1px #9EA5AB;
    @include smMax{
      margin-top: sm_vw(100);
    }
    &__item {
      border-bottom: solid 1px #9EA5AB;
      > a {
        padding: 40px 0;
        display: flex;
        align-items: center;
        @include smMax{
          padding: sm_vw(80) 0;
          flex-direction: column;
        }
        @include hover{
          opacity: 0.7;
          .company-list__img img {
            transform: scale(1.05);
          }
        }
      }
    }
    &__img {
      @include smMin {
        width: 360px;
        margin-right: 40px;
        overflow: hidden;
      }
      @include smMax {
        width: 100%;
      }
      img {
        pointer-events: none;
      }
    }
    &__detail {
      @include smMin {
        width: calc(100% - 400px);
      }
    }
    &__tag {
      display: flex;
      flex-wrap: wrap;
      margin-top: 10px;
      li {
        margin-right: 8px;
        margin-bottom: 8px;
        height: 24px;
        padding: 0 10px;
        background: #FFF;
        border-radius: 12px;
        font-size: 1.2rem;
        display: flex;
        justify-content: center;
        align-items: center;
        border: solid 1px #000;
        @include smMax{
          font-size: sm_vw(22);
          height: sm_vw(40);
          padding: 0 sm_vw(14);
        }
      }
    }
    &__date {
      color: $colorPlain;
      font-family: $font-en;
      font-weight: 500;
      font-size: 1.2rem;
      @include smMax {
        font-size: sm_vw(24);
        margin-top: sm_vw(20);
      }
    }
    &__title {
      font-size: 2.2rem;
      font-weight: 500;
      line-height: 1.8;
      margin-top: 5px;
      @include smMax {
        font-size: sm_vw(32);
        margin-top: sm_vw(5);
      }
    }
  }
</style>

