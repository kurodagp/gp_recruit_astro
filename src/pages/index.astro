---
import '../scss/style.scss';
import '../scss/top.scss';
import Base from './layouts/base.astro';
import Container from './layouts/container.astro';
import Page from './layouts/page.astro';
import Header from './layouts/header.astro';
import Footer from './layouts/footer.astro';
import Anchor from '../components/Anchor.astro';
import Sidebar from '../components/Sidebar.astro';

import RelationCard from '../components/RelationCard.astro';
import RelationList from '../components/RelationList.astro';
import CompanyList from '../components/CompanyList.astro';
import ValuesList from '../components/ValuesList.astro';
import WorkList from '../components/WorkList.astro';
---

<Base 
  pageTitle="GROW-PLATHX [グロウプレイス] | ジーピーオンラインの採用オウンドメディア"
  pageDescription="GROW-PLATHX [グロウプレイス]は、ジーピーオンラインで働く社員のインタビューや、働く環境、価値観、仕事内容の紹介など、私たちがありがとうをつくり、成長していく姿をお届けする採用オウンドメディアです。"
>

<Page pageParameter='top'>
  
  <Header />
  
  <Container>
    <section class="mv" id="mv">
      <div class="mv-news">
        <div class="mv-news-wrap">
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
        </div>
        <div class="mv-news-wrap">
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
          <dl class="mv-news__item">
            <dt>2025.11.20</dt>
            <dd>新着記事を追加しました🎈</dd>
          </dl>
        </div>
      </div>
      <div class="l-inner mv-inner">
        <div class="mv-container flex-container">
          <div class="mv-container--main main-content">
            <div class="mv-lead">
              <h1 class="mv-lead__title">
                <picture>
                  <source media="(max-width: 767px)" srcset="/blog/assets/images/top/mv_ttl_sp.svg">
                  <img src="/blog/assets/images/top/mv_ttl.svg" alt="GROW-PLATHX【グロウプレイス】ありがとうをつくり、ともに成長する">
                </picture>
              </h1>
              <div class="mv-lead__wrap">
                <p class="mv-lead__text">ここではジーピーオンラインの人、会社、価値観、<br class="u-sm-min">仕事に関する情報をお届けしています。<br>あなたが、ここであなたらしく“成長”できる日々を過ごせるように。<br>そして、私たちは今日も成長に会いにいく。</p>
                <p class="mv-lead__btn">
                  <a href="https://www.gpol.co.jp/recruit/" target="_blank"><span>採用サイトを見る</span></a>
                </p>
              </div>
            </div>
            <Anchor items={[
              { anchor: 'people', title: 'PEOPLE', subtitle: 'ひと' },
              { anchor: 'company', title: 'COMPANY', subtitle: 'はたらく環境' },
              { anchor: 'values', title: 'VALUES', subtitle: '価値観' },
              { anchor: 'work', title: 'WORK', subtitle: '仕事' }
            ]} />
          </div>
          <div class="mv-container--side side-content">
            <div class="mv-recommend">
              <h2 class="mv-recommend__ttl">RECOMMEND</h2>
              <div class="mv-recommend__slider">
                <ul class="mv-recommend__list swiper-wrapper">
                  <li class="swiper-slide">
                    <a href="/blog/2.html">
                      <div class="mv-recommend__img"><img src="/blog/assets/images/blog/2/kv.jpg" alt=""></div>
                      <p class="mv-recommend__date">2024.10.09</p>
                      <p class="mv-recommend__title">顧客視点に立てば、成果は後からついてくる</p>
                    </a>
                  </li>
                  <li class="swiper-slide">
                    <a href="/blog/23.html">
                      <div class="mv-recommend__img"><img src="/blog/assets/images/blog/23/kv.jpg" alt=""></div>
                      <p class="mv-recommend__date">2025.11.20</p>
                      <p class="mv-recommend__title">技術は変わっても、“つくる楽しさ”は変わらない。エンジニアが語る仕事の原点</p>
                    </a>
                  </li>
                  <li class="swiper-slide">
                    <a href="/blog/20.html">
                      <div class="mv-recommend__img"><img src="/blog/assets/images/blog/20/kv.jpg" alt=""></div>
                      <p class="mv-recommend__date">2025.09.26</p>
                      <p class="mv-recommend__title">経験を“次のステージ”へ ─ 広がり続けるデザインキャリア</p>
                    </a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="headerPos"></div>
    </section>

    <!-- newest -->
    <section class="newest" id="newest">
      <div class="l-inner newest-inner">
        <h2 class="newest__ttl ttl01 typing-anime">
          <span>新着記事</span>
          <b class="typing typing01">ジーピー<br class="u-sm-max">オンラインの今</b>
        </h2>
        <div class="newest-container flex-container">
          <div class="newest-container--main main-content">
            <div class="relation">
              <RelationList />
            </div>
            <div class="relation-more">
              <a href="all.html">
                <div class="relation-more__btn">READ MORE</div>
              </a>
            </div>
          </div>
          <div class="newest-container--side side-content">
            <Sidebar />
          </div>
        </div>
      </div>
    </section>

    <!-- people -->
    <section class="people fixed-title--pos" id="people">
      <div class="l-inner people-inner">
        <div class="people-detail">
          <h2 class="people__ttl ttl01 typing-anime">
            <span>ひと</span>
            <b class="typing typing01">良い人と一緒に、</b>
            <b class="typing typing02">良い仕事を</b>
          </h2>
          <p class="people__lead">毎日、たくさんの人と<br>関わりながら過ごしていく。<br>周りにたくさんの良い人がいるから、<br>良い仕事ができる。</p>
        </div>
        <div class="people__slider">
          <ul class="people-list swiper-wrapper">
            <li class="people-list__item swiper-slide">
              <a href="/blog/20.html">
                <figure class="people-list__img">
                  <img src="/blog/assets/images/top/people_list07.jpg" srcset="/blog/assets/images/top/people_list07@2x.jpg 2x" alt="">
                </figure>
                <dl class="people-list__detail">
                  <dt class="people-list__title">
                    <p>経験を“次のステージ”へ<br>広がり続ける<br>デザインキャリア</p>
                  </dt>
                  <dd>
                    <ul class="people-list__tagList">
                      <li class="people-list__tag">#中途</li>
                      <li class="people-list__tag">#Webデザイナー</li>
                      <li class="people-list__tag">#アートディレクター</li>
                    </ul>
                  </dd>
                </dl>
              </a>
            </li>
            <li class="people-list__item swiper-slide">
              <a href="/blog/17.html">
                <figure class="people-list__img">
                  <img src="/blog/assets/images/top/people_list06.jpg" srcset="/blog/assets/images/top/people_list06@2x.jpg 2x" alt="">
                </figure>
                <dl class="people-list__detail">
                  <dt class="people-list__title">
                    <p>好奇心が導いた<br>アカウントプランナーの<br>成長ストーリー</p>
                  </dt>
                  <dd>
                    <ul class="people-list__tagList">
                      <li class="people-list__tag">#中途</li>
                      <li class="people-list__tag">#アカウントプランナー</li>
                      <li class="people-list__tag">#企画営業</li>
                      <li class="people-list__tag">#アカウントDiv</li>
                    </ul>
                  </dd>
                </dl>
              </a>
            </li>
            <li class="people-list__item swiper-slide">
              <a href="/blog/16.html">
                <figure class="people-list__img">
                  <img src="/blog/assets/images/top/people_list05.jpg" srcset="/blog/assets/images/top/people_list05@2x.jpg 2x" alt="">
                </figure>
                <dl class="people-list__detail">
                  <dt class="people-list__title">
                    <p>“共創”の原点に<br>あるのは<br>飾らない“正直さ”</p>
                  </dt>
                  <dd>
                    <ul class="people-list__tagList">
                      <li class="people-list__tag">#Webディレクター</li>
                      <li class="people-list__tag">#プロデュースG</li>
                      <li class="people-list__tag">#中途</li>
                    </ul>
                  </dd>
                </dl>
              </a>
            </li>
            <li class="people-list__item swiper-slide">
              <a href="/blog/10.html">
                <figure class="people-list__img">
                  <img src="/blog/assets/images/top/people_list03.jpg" srcset="/blog/assets/images/top/people_list03@2x.jpg 2x" alt="">
                </figure>
                <dl class="people-list__detail">
                  <dt class="people-list__title">
                    <p>ジーピーオンラインで<br>「成長」を叶える<br>秘訣とは？</p>
                  </dt>
                  <dd>
                    <ul class="people-list__tagList">
                      <li class="people-list__tag">#新卒</li>
                      <li class="people-list__tag">#Webディレクター</li>
                      <li class="people-list__tag">#プロデュースG</li>
                      <li class="people-list__tag">#未経験者</li>
                    </ul>
                  </dd>
                </dl>
              </a>
            </li>
            <li class="people-list__item swiper-slide">
              <a href="/blog/5.html">
                <figure class="people-list__img">
                  <img src="/blog/assets/images/top/people_list02.jpg" srcset="/blog/assets/images/top/people_list02@2x.jpg 2x" alt="">
                </figure>
                <dl class="people-list__detail">
                  <dt class="people-list__title">
                    <p>デザイナーの成長と挑戦<br>アートディレクターの<br>道を切り開く</p>
                  </dt>
                  <dd>
                    <ul class="people-list__tagList">
                      <li class="people-list__tag">#アートディレクター</li>
                      <li class="people-list__tag">#Webデザイナー</li>
                      <li class="people-list__tag">#クリエイティブDiv</li>
                      <li class="people-list__tag">#新卒</li>
                    </ul>
                  </dd>
                </dl>
              </a>
            </li>
          </ul>
          <div class="swiper-button">
            <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div>
          </div>
        </div>
      </div>
      <div class="l-inner u-w-100">
        <div class="people-more">
          <a href="people.html">
            <div class="people-more__btn">READ MORE</div>
          </a>
        </div>
      </div>
    </section>

    <!-- company -->
    <section class="company fixed-title--pos" id="company">
      <div class="l-inner company-inner">
        <h2 class="company__ttl ttl01 typing-anime">
          <span>はたらく環境</span>
          <b class="typing typing01">全員で<br class="u-sm-max">居心地の良い場所を<br class="u-sm-max">つくっています</b>
        </h2>
        <p class="company__lead">ジーピーオンラインは毎日過ごす大切な場所。<br>社員の成長とともに、会社も日々成長していく。</p>
        <CompanyList />
        <div class="company-more">
          <a href="company.html">
            <div class="company-more__btn">READ MORE</div>
          </a>
        </div>
      </div>
    </section>

    <!-- values -->
    <section class="values fixed-title--pos" id="values">
      <div class="l-inner values-inner">
        <h2 class="values__ttl ttl01 typing-anime">
          <span>価値観</span>
          <b class="typing typing01">常に“ありがとう”を<br class="u-sm-max">考え、行動する</b>
        </h2>
        <p class="values__lead">仲間からの"ありがとう"は、<br class="u-sm-max">高いモチベーション。<br>お客さまからの"ありがとう"で、さらなる成長を。</p>
        <ValuesList />
        <div class="values-more">
          <a href="values.html">
            <div class="values-more__btn">READ MORE</div>
          </a>
        </div>
      </div>
    </section>

    <!-- work -->
    <section class="work fixed-title--pos" id="work">
      <div class="l-inner work-inner">
        <h2 class="work__ttl ttl01 typing-anime">
          <span>仕事</span>
          <b class="typing typing01">私たちの<br class="u-sm-max">“成長”のヒケツ</b>
        </h2>
        <p class="work__lead">人それぞれ、仕事における成長の機会や時間は違う。<br>だけど、ここでの仕事はきっとあなたが望む成長になる。</p>
        <WorkList />
        <div class="work-more">
          <a href="work.html">
            <div class="work-more__btn">READ MORE</div>
          </a>
        </div>
      </div>
    </section>

    <ul class="fixed-title">
      <li data-title="people">PEOPLE</li>
      <li data-title="company">COMPANY</li>
      <li data-title="values">VALUES</li>
      <li data-title="work">WORK</li>
    </ul>
  </Container>

  <Footer />
</Page>
</Base>